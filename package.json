{
  "name": "modelbound",
  "version": "0.3.1",
  "description": "ModelBound CLI — token optimization, skill pipeline, and version management from your terminal.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "modelbound": "dist/index.js",
    "mb": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "ink": "^5.0.1",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.3",
    "eslint": "^10.5.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ModelBound/modelbound-cli.git"
  },
  "homepage": "https://modelbound.co",
  "keywords": [
    "modelbound",
    "cli",
    "agent-skills",
    "context-engineering",
    "prompt-engineering",
    "token-optimization",
    "skill-pipeline",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "devops",
    "ci-cd",
    "generative-ai",
    "llm"
  ]
}
